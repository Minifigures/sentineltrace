# SentinelTrace env template. Copy to .env and fill in. NEVER commit .env.
# Union of all subsystem keys; per-subsystem .env.example files are subsets.

# ---- Local stack (Docker) ----
KAFKA_BOOTSTRAP=localhost:19092          # Redpanda locally; Event Hubs endpoint in cloud
KAFKA_MODE=local                          # local | eventhubs
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
POSTGRES_DSN=postgresql://sentinel:sentinel@localhost:5432/sentinel

# ---- Audit ----
AUDIT_HASH_ALGO=sha256                    # sha256 (default, cross-language safe) | blake3

# ---- Azure (filled in at the cloud phase; leave blank until then) ----
# Azure for Students sub, no card; CA$139 credit is the hard backstop. Budget cap CA$100.
AZURE_SUBSCRIPTION_ID=
AZURE_REGION=eastus2                       # forced: gpt-4o GlobalStandard + safety evaluators are eastus2-only on this sub
# Databricks: Free Edition (serverless only) — do NOT start the 14-day trial; detectors run locally.
EVENTHUBS_CONNECTION_STRING=              # paste here
ADLS_ACCOUNT=
AZURE_OPENAI_ENDPOINT=                    # paste here
AZURE_OPENAI_API_KEY=                     # paste here (secret)
AZURE_AI_SEARCH_ENDPOINT=
AZURE_AI_SEARCH_KEY=                      # paste here (secret)
AZURE_CONTENT_SAFETY_ENDPOINT=

# ---- Databricks (Free Edition serverless; cloud phase P8) ----
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com   # Free Edition, serverless only
DATABRICKS_TOKEN=                         # paste here (secret; generate a PAT in the workspace)

# ---- Web ----
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_DEMO_MOCK=false
